{
    "name": "mitsuki/db-migrations",
    "description": "A lightweight, fluent database migration wrapper for the Mitsuki framework, built on top of Phinx.",
    "keywords": [
        "mitsuki",
        "php",
        "framework",
        "database",
        "migrations",
        "schema-builder",
        "fluent-api",
        "phinx-wrapper"
    ],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Mitsuki\\Database\\": "src/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Zgeniuscoders",
            "email": "zgeniuscoders@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "robmorgan/phinx": "^0.16.10",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^4.4",
        "mockery/mockery": "^1.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
